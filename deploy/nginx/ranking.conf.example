# Copiar a /var/www/ranking.clubatleticcastellar.cat/conf/nginx/ranking.conf
# Este fichero se incluye dentro del bloque server existente.

# La portada publica se sirve en / y la gestion autenticada en /admin/.
location = /admin {
    return 308 /admin/;
}

# La API usa rutas REST y un unico front controller PHP.
location = /api {
    return 308 /api/;
}

location /api/ {
    try_files $uri /api/index.php?$query_string;
}

# El document root contiene las herramientas de despliegue, que nunca son publicas.
# ^~ evita que una regla PHP generica ejecute scripts de estas carpetas.
location = /.env {
    deny all;
}

location = /.env.example {
    deny all;
}

location = /.gitignore {
    deny all;
}

location = /config.php {
    deny all;
}

location ^~ /.git/ {
    deny all;
}

location ^~ /.vscode/ {
    deny all;
}

location ^~ /database/ {
    deny all;
}

location ^~ /lib/ {
    deny all;
}

location ^~ /scripts/ {
    deny all;
}

location ^~ /storage/ {
    deny all;
}

location ^~ /uploads/ {
    deny all;
}

location ^~ /logs/ {
    deny all;
}

location ^~ /cache/ {
    deny all;
}

location ^~ /backups/ {
    deny all;
}

location ^~ /deploy/ {
    deny all;
}

location ^~ /vendor/ {
    deny all;
}
