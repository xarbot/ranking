{
  "servers": {
    "rankingFilesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "/data/repos/ranking"
      ],
      "cwd": "/data/repos/ranking"
    },
    "rankingTools": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/data/mcp/ranking-tools/server.py"
      ],
      "cwd": "/data/repos/ranking"
    }
  }
}
